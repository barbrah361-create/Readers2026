# Readers Platform Configuration

APP_URL="http://localhost:3000"
PORT=3000
SESSION_SECRET="change-this-to-a-random-secret-in-production"
NODE_ENV="development"

# Admin Account (created on first boot if missing)
ADMIN_EMAIL="admin@readers.africa"
ADMIN_PASSWORD="admin"

# Email (SMTP) - leave blank for dev mode (emails logged to console)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Readers <noreply@readers.africa>"

# M-Pesa Daraja API (Safaricom)
MPESA_ENV="sandbox"
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_SHORTCODE="174379"
MPESA_PASSKEY=""

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI (optional, future features)
GEMINI_API_KEY=""

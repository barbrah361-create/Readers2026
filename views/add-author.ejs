<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex-grow">
  
  <div class="mb-8 border-b border-brand-brown/10 dark:border-brand-brown/25 pb-6">
    <a href="/admin/authors" class="text-xs font-semibold text-brand-brown dark:text-brand-pink hover:underline flex items-center gap-1 mb-2">&larr; Back to Authors Manager</a>
    <h1 class="font-serif text-3xl font-bold text-gray-800 dark:text-brand-pink">Add Famous Author</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Enroll a legendary writer, philosopher, or historic poet into the library registries.</p>
  </div>

  <form action="/admin/authors/add" method="POST" enctype="multipart/form-data" class="bg-white dark:bg-[#1E150F] p-6 sm:p-10 rounded-2xl shadow-sm border border-brand-brown/10 dark:border-brand-brown/20 space-y-6">
    
    <!-- Name & Nationality -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        <label for="name" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Author Full Name</label>
        <input type="text" id="name" name="name" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-brand-cream/10 text-gray-800 dark:text-white focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all" placeholder="e.g. Leo Tolstoy">
      </div>
      <div>
        <label for="nationality" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Nationality</label>
        <input type="text" id="nationality" name="nationality" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-brand-cream/10 text-gray-800 dark:text-white focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all" placeholder="e.g. Russian">
      </div>
    </div>

    <!-- Photo Upload -->
    <div>
      <label for="photo" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Portrait Photo</label>
      <input type="file" id="photo" name="photo" accept="image/*" class="block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-brand-brown file:text-white hover:file:bg-brand-accent">
      <p class="text-xs text-gray-400 mt-1.5 font-light">Supported: png, jpg, jpeg, webp. Limit 5MB. If omitted, a clean generic avatar will represent the author.</p>
    </div>

    <!-- Achievements & Famous Novels -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        <label for="literaryAchievements" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Literary Achievements / Awards</label>
        <input type="text" id="literaryAchievements" name="literaryAchievements" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-brand-cream/10 text-gray-800 dark:text-white focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all" placeholder="e.g. Nobel Prize in Literature (1902)">
      </div>
      <div>
        <label for="famousNovels" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Famous Masterpieces List</label>
        <input type="text" id="famousNovels" name="famousNovels" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-brand-cream/10 text-gray-800 dark:text-white focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all" placeholder="e.g. War and Peace, Anna Karenina">
      </div>
    </div>

    <!-- Biography -->
    <div>
      <label for="bio" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Author Biography</label>
      <textarea id="bio" name="bio" rows="6" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-brand-cream/10 text-gray-800 dark:text-white placeholder-gray-400 focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all" placeholder="Write detailed biographical records, historical milestones, and literary philosophies..."></textarea>
    </div>

    <div class="flex items-center justify-end gap-3 pt-4 border-t border-brand-brown/10 dark:border-brand-brown/25">
      <a href="/admin/authors" class="px-5 py-3 rounded-xl border border-brand-brown/20 text-gray-700 dark:text-gray-300 font-semibold text-sm hover:bg-brand-cream/10">Cancel</a>
      <button type="submit" class="px-6 py-3 bg-brand-brown hover:bg-brand-accent text-white font-semibold rounded-xl shadow-md hover:shadow-lg transition-all duration-200 text-sm flex items-center gap-2">
        <i data-lucide="plus" class="w-4.5 h-4.5"></i>
        Enroll Author
      </button>
    </div>

  </form>
</div>

<%- include('partials/footer') %>

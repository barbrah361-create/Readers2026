<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex-grow">
  
  <!-- 1. Welcome Header Banner -->
  <div class="relative overflow-hidden rounded-3xl bg-gradient-to-r from-brand-brown to-brand-dark text-white p-8 sm:p-12 shadow-md mb-12 border-2 border-brand-pink/10">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(247,214,224,0.15),transparent_50%)]"></div>
    <div class="relative z-10 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-6 text-center sm:text-left flex-col sm:flex-row">
        <img src="<%= user.avatar || '/uploads/default-avatar.png' %>" alt="<%= user.username %>" class="w-20 h-20 rounded-full object-cover border-4 border-brand-pink shadow-md">
        <div>
          <h1 class="font-serif text-3xl sm:text-4xl font-bold tracking-tight">Welcome Back, <span class="text-brand-pink"><%= user.username %></span></h1>
          <p class="text-gray-300 font-light mt-1 text-sm sm:text-base">We hope your day is filled with inspiring chapters. Let's delve back in.</p>
        </div>
      </div>
      <a href="/novels" class="px-6 py-3 bg-brand-pink hover:bg-white text-brand-dark font-bold rounded-xl shadow-md transition-all duration-200 text-sm flex items-center gap-2 flex-shrink-0">
        <i data-lucide="compass" class="w-4.5 h-4.5"></i>
        Browse Library
      </a>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
    
    <!-- LEFT PANEL: Active reading history and favorites (Col span 8) -->
    <div class="lg:col-span-8 space-y-12">
      
      <!-- Section A: Continue Reading & Progress Tracker -->
      <div class="bg-white dark:bg-[#1E150F] p-6 sm:p-8 rounded-2xl border border-brand-brown/10 dark:border-brand-brown/20 shadow-sm">
        <div class="flex items-center justify-between mb-6 border-b border-brand-brown/10 dark:border-brand-brown/15 pb-4">
          <h2 class="font-serif text-2xl font-bold text-gray-800 dark:text-brand-pink flex items-center gap-2.5">
            <i data-lucide="book-open-check" class="w-6 h-6 text-brand-brown dark:text-brand-pink"></i>
            Continue Reading
          </h2>
          <a href="/history" class="text-xs font-semibold text-brand-brown dark:text-brand-pink hover:underline">View Reading History</a>
        </div>

        <% if (historyItems.length > 0) { %>
          <div class="space-y-6">
            <% historyItems.slice(0, 3).forEach(function(item) { %>
              <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between p-4 rounded-xl bg-brand-cream/25 dark:bg-brand-brown/5 border border-brand-brown/5 dark:border-brand-brown/10 gap-4 hover:border-brand-pink transition-colors">
                <div class="flex items-center gap-4">
                  <img src="<%= item.novel.coverImage %>" alt="<%= item.novel.title %>" class="w-14 h-20 rounded-lg object-cover shadow-sm">
                  <div>
                    <h3 class="font-serif text-lg font-bold text-gray-800 dark:text-white leading-snug"><%= item.novel.title %></h3>
                    <p class="text-xs text-gray-400">By <%= item.novel.authorName %> &bull; Page <%= item.pageIndex + 1 %> of <%= item.novel.contentPages.length %></p>
                    
                    <!-- Progress Bar -->
                    <div class="mt-3.5 w-44 sm:w-56 bg-gray-250 dark:bg-brand-brown/20 rounded-full h-2 overflow-hidden flex">
                      <div class="bg-brand-brown dark:bg-brand-pink h-full" style="width: <%= item.progressPercent %>%"></div>
                    </div>
                  </div>
                </div>

                <div class="flex items-center gap-3 w-full sm:w-auto justify-end">
                  <span class="text-xs font-bold text-brand-brown dark:text-brand-pink"><%= item.progressPercent %>% Done</span>
                  <a href="/novels/<%= item.novelId %>/read?page=<%= item.pageIndex %>" class="px-4 py-2 bg-brand-brown hover:bg-brand-accent text-white font-semibold rounded-lg text-xs shadow-sm transition-colors flex items-center gap-1.5">
                    Resume
                    <i data-lucide="play" class="w-3.5 h-3.5 fill-white"></i>
                  </a>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="text-center py-12 text-gray-400">
            <i data-lucide="notebook-tabs" class="w-12 h-12 text-gray-300 mx-auto mb-4"></i>
            <p class="text-sm">No books opened yet. Begin reading online and your history will appear here.</p>
          </div>
        <% } %>
      </div>

      <!-- Section B: Favorite Novels Shelf -->
      <div class="bg-white dark:bg-[#1E150F] p-6 sm:p-8 rounded-2xl border border-brand-brown/10 dark:border-brand-brown/20 shadow-sm">
        <div class="flex items-center justify-between mb-6 border-b border-brand-brown/10 dark:border-brand-brown/15 pb-4">
          <h2 class="font-serif text-2xl font-bold text-gray-800 dark:text-brand-pink flex items-center gap-2.5">
            <i data-lucide="heart" class="w-6 h-6 text-red-500 fill-red-500"></i>
            My Favorite Books
          </h2>
          <a href="/favorites" class="text-xs font-semibold text-brand-brown dark:text-brand-pink hover:underline">Manage Shelf</a>
        </div>

        <% if (favoriteNovels.length > 0) { %>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <% favoriteNovels.slice(0, 4).forEach(function(novel) { %>
              <div class="flex items-center gap-4 p-3 rounded-xl border border-brand-brown/5 dark:border-brand-brown/10 hover:shadow-md transition-all duration-200">
                <img src="<%= novel.coverImage %>" alt="<%= novel.title %>" class="w-16 h-24 rounded-lg object-cover shadow-sm">
                <div class="min-w-0 flex-grow">
                  <h3 class="font-serif text-base font-bold text-gray-800 dark:text-white truncate"><%= novel.title %></h3>
                  <p class="text-xs text-gray-400 mt-0.5">By <%= novel.authorName %></p>
                  <span class="inline-block mt-2.5 bg-brand-pink/20 text-brand-brown dark:text-brand-pink text-[10px] font-bold px-2 py-0.5 rounded-md"><%= novel.genre %></span>
                  
                  <div class="mt-3 flex items-center gap-2">
                    <a href="/novels/<%= novel._id %>" class="text-xs font-bold text-brand-brown dark:text-brand-pink hover:underline flex items-center gap-0.5">
                      Explore Details
                      <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
                    </a>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="text-center py-12 text-gray-400">
            <i data-lucide="heart-off" class="w-12 h-12 text-gray-300 mx-auto mb-4"></i>
            <p class="text-sm">Your favorite books shelf is currently empty.</p>
          </div>
        <% } %>
      </div>

    </div>

    <!-- RIGHT PANEL: Bookmarks and Recommendations (Col span 4) -->
    <div class="lg:col-span-4 space-y-12">
      
      <!-- Section C: Active Bookmarks -->
      <div class="bg-white dark:bg-[#1E150F] p-6 sm:p-8 rounded-2xl border border-brand-brown/10 dark:border-brand-brown/20 shadow-sm h-fit">
        <h2 class="font-serif text-2xl font-bold text-gray-800 dark:text-brand-pink mb-6 pb-4 border-b border-brand-brown/10 dark:border-brand-brown/15 flex items-center gap-2.5">
          <i data-lucide="bookmark" class="w-5 h-5 text-brand-brown dark:text-brand-pink fill-brand-brown dark:fill-brand-pink"></i>
          My Bookmarks
        </h2>

        <% if (bookmarkItems.length > 0) { %>
          <div class="space-y-4">
            <% bookmarkItems.forEach(function(item) { %>
              <div class="p-3.5 rounded-xl bg-brand-cream/25 dark:bg-brand-brown/5 border border-brand-brown/5 dark:border-brand-brown/10 text-xs">
                <div class="flex items-center gap-3">
                  <img src="<%= item.novel.coverImage %>" alt="" class="w-8 h-12 object-cover rounded-md flex-shrink-0">
                  <div class="min-w-0">
                    <p class="font-bold text-gray-800 dark:text-white truncate"><%= item.novel.title %></p>
                    <p class="text-gray-400 mt-0.5">Page <%= item.pageIndex + 1 %> of <%= item.novel.contentPages.length %></p>
                  </div>
                </div>
                <div class="mt-3.5 flex items-center justify-between border-t border-brand-brown/5 dark:border-brand-brown/10 pt-2.5">
                  <span class="text-gray-400 text-[10px]"><%= new Date(item.bookmarkedAt).toLocaleDateString() %></span>
                  <a href="/novels/<%= item.novelId %>/read?page=<%= item.pageIndex %>" class="text-brand-brown dark:text-brand-pink font-semibold hover:underline flex items-center gap-1">
                    Jump to Page
                    <i data-lucide="arrow-right" class="w-3.5 h-3.5"></i>
                  </a>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="text-center py-8 text-gray-400">
            <i data-lucide="bookmark-x" class="w-10 h-10 text-gray-300 mx-auto mb-3"></i>
            <p class="text-xs">No active bookmarks found.</p>
          </div>
        <% } %>
      </div>

      <!-- Section D: Recommended Novels -->
      <div class="bg-white dark:bg-[#1E150F] p-6 sm:p-8 rounded-2xl border border-brand-brown/10 dark:border-brand-brown/20 shadow-sm h-fit">
        <h2 class="font-serif text-2xl font-bold text-gray-800 dark:text-brand-pink mb-6 pb-4 border-b border-brand-brown/10 dark:border-brand-brown/15 flex items-center gap-2.5">
          <i data-lucide="sparkles" class="w-5 h-5 text-brand-brown dark:text-brand-pink"></i>
          Recommended
        </h2>

        <% if (recommendedNovels.length > 0) { %>
          <div class="space-y-5">
            <% recommendedNovels.forEach(function(novel) { %>
              <div class="group flex gap-4">
                <img src="<%= novel.coverImage %>" alt="<%= novel.title %>" class="w-12 h-18 rounded-lg object-cover shadow-sm group-hover:scale-105 transition-transform">
                <div class="min-w-0 flex-grow">
                  <h3 class="font-serif text-sm font-bold text-gray-800 dark:text-white truncate group-hover:text-brand-brown dark:group-hover:text-brand-pink transition-colors"><%= novel.title %></h3>
                  <p class="text-[10px] text-gray-400">By <%= novel.authorName %></p>
                  <div class="flex items-center gap-1 mt-1.5">
                    <i data-lucide="star" class="w-3.5 h-3.5 text-amber-500 fill-amber-500"></i>
                    <span class="text-[10px] font-semibold text-gray-600 dark:text-gray-300"><%= novel.rating %></span>
                  </div>
                  <a href="/novels/<%= novel._id %>" class="inline-block mt-2 text-[10px] font-bold text-brand-brown dark:text-brand-pink hover:underline">&rarr; Read Details</a>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <p class="text-xs text-gray-400 text-center py-6">You have read all our available masterpieces! Check back later for fresh collections.</p>
        <% } %>
      </div>

    </div>

  </div>
</div>

<%- include('partials/footer') %>

<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex-grow">
  
  <!-- 1. Author profile Header Details -->
  <div class="bg-white dark:bg-[#1E150F] p-6 sm:p-10 rounded-3xl border border-brand-brown/10 dark:border-brand-brown/20 shadow-sm mb-12">
    <div class="flex flex-col md:flex-row items-center md:items-start gap-8 sm:gap-10">
      
      <!-- Photo -->
      <img src="<%= author.photo || '/uploads/default-avatar.png' %>" alt="<%= author.name %>" class="w-36 h-36 rounded-full object-cover shadow-md ring-4 ring-brand-pink/30 flex-shrink-0">

      <!-- Text details -->
      <div class="flex-grow text-center md:text-left space-y-4">
        <div>
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-brand-pink/20 text-brand-brown dark:text-brand-pink">
            <i data-lucide="feather" class="w-3.5 h-3.5"></i>
            Archived Biography
          </span>
          <h1 class="font-serif text-3xl sm:text-4xl font-bold mt-2 text-gray-800 dark:text-white"><%= author.name %></h1>
          <p class="text-sm text-gray-400 mt-1">Origin: <span class="font-bold text-gray-650 dark:text-gray-300"><%= author.nationality %></span></p>
        </div>

        <div class="p-4 rounded-xl bg-brand-cream/30 dark:bg-brand-brown/10 border border-brand-brown/5 text-xs text-left max-w-2xl space-y-1.5">
          <p class="font-bold text-gray-700 dark:text-white">🏆 Literary Achievements:</p>
          <p class="text-gray-600 dark:text-gray-300"><%= author.literaryAchievements %></p>
          <p class="font-bold text-gray-700 dark:text-white pt-1">📖 Historical Masterpieces:</p>
          <p class="text-gray-600 dark:text-gray-300"><%= author.famousNovels %></p>
          <% if (author.externalLink) { %>
            <a href="<%= author.externalLink %>" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mt-3 text-sm font-semibold text-brand-pink hover:text-brand-brown transition-colors">
              <i data-lucide="external-link" class="w-4 h-4"></i>
              Explore this author online
            </a>
          <% } %>
        </div>
      </div>

    </div>

    <!-- Biography long text -->
    <div class="mt-8 pt-8 border-t border-brand-brown/10 dark:border-brand-brown/15">
      <h2 class="font-serif text-xl font-bold text-gray-800 dark:text-brand-pink mb-4">Biographical Narrative</h2>
      <div class="prose prose-amber dark:prose-invert text-gray-700 dark:text-gray-300 text-sm sm:text-base leading-relaxed space-y-4">
        <% author.bio.split('\n\n').forEach(function(para) { %>
          <p><%= para %></p>
        <% }) %>
      </div>
    </div>
  </div>

  <!-- 2. Novels linked to this author catalog -->
  <div class="space-y-6">
    <h2 class="font-serif text-2xl sm:text-3xl font-bold text-gray-800 dark:text-brand-pink">Published Books in Our Stacks</h2>
    
    <% if (novels.length > 0) { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <% novels.forEach(function(novel) { %>
          <div class="group bg-white dark:bg-[#1E150F] rounded-2xl overflow-hidden shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 border border-brand-brown/5 dark:border-brand-brown/15 flex flex-col h-full">
            <!-- Cover image -->
            <div class="relative h-60 overflow-hidden bg-brand-cream/50">
              <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="<%= novel.coverImage %>" alt="<%= novel.title %>" loading="lazy">
              <div class="absolute top-3 right-3 bg-white/95 dark:bg-brand-dark/95 backdrop-blur px-2 py-1 rounded-lg border border-brand-brown/15 flex items-center gap-1 text-[10px] font-bold text-gray-850 dark:text-brand-pink">
                <i data-lucide="star" class="w-3 h-3 text-amber-500 fill-amber-500"></i>
                <%= novel.rating %>
              </div>
              <span class="absolute bottom-3 left-3 bg-brand-brown text-brand-cream text-[9px] px-2 py-0.5 rounded font-semibold uppercase tracking-wider">
                <%= novel.genre %>
              </span>
            </div>

            <!-- Details -->
            <div class="p-5 flex flex-col flex-grow">
              <h3 class="font-serif text-base font-bold text-gray-800 dark:text-white group-hover:text-brand-brown dark:group-hover:text-brand-pink transition-colors truncate">
                <%= novel.title %>
              </h3>
              <p class="text-xs text-gray-500 dark:text-gray-300 line-clamp-2 leading-relaxed mb-4 flex-grow mt-1">
                <%= novel.description %>
              </p>

              <div class="flex items-center justify-between border-t border-brand-brown/10 dark:border-brand-brown/15 pt-3.5 mt-auto">
                <span class="text-[10px] font-medium text-gray-400 flex items-center gap-1">
                  <i data-lucide="eye" class="w-3.5 h-3.5 text-brand-brown dark:text-brand-pink"></i>
                  <%= novel.readerCount %> reads
                </span>
                <a href="/novels/<%= novel._id %>" class="px-3 py-1 bg-brand-cream hover:bg-brand-pink/30 text-brand-brown dark:text-brand-pink font-semibold rounded-lg text-[11px] transition-colors">
                  Read details &rarr;
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="bg-white dark:bg-[#1E150F] p-10 rounded-2xl border border-brand-brown/10 text-center text-gray-400">
        <i data-lucide="book-x" class="w-12 h-12 text-gray-300 mx-auto mb-3"></i>
        <p class="text-sm">We currently do not hold any published copies under this author's name.</p>
      </div>
    <% } %>
  </div>

</div>

<%- include('partials/footer') %>

<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex-grow">
  
  <div class="mb-8 border-b border-brand-brown/10 dark:border-brand-brown/25 pb-6">
    <a href="/dashboard" class="text-xs font-semibold text-brand-brown dark:text-brand-pink hover:underline flex items-center gap-1 mb-2">&larr; Back to Reader Dashboard</a>
    <h1 class="font-serif text-3xl font-bold text-gray-800 dark:text-brand-pink flex items-center gap-2">
      <i data-lucide="notebook-tabs" class="w-7 h-7 text-brand-brown dark:text-brand-pink"></i>
      Reading Progress Logs
    </h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1 font-light font-sans">A complete historic log of books you have opened online, including detailed completion percentages and page checkpoints.</p>
  </div>

  <% if (history.length > 0) { %>
    <div class="bg-white dark:bg-[#1E150F] rounded-2xl shadow-sm border border-brand-brown/10 dark:border-brand-brown/20 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b border-brand-brown/10 dark:border-brand-brown/15 bg-brand-cream/10 text-xs text-gray-400 font-bold uppercase">
              <th class="py-4 px-6">Book Title & Author</th>
              <th class="py-4 px-6">Genre Shelf</th>
              <th class="py-4 px-6">Checkpoint Page</th>
              <th class="py-4 px-6">Progress Completeness</th>
              <th class="py-4 px-6">Last Opened At</th>
              <th class="py-4 px-6 text-right">Resume Reading</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-brand-brown/5 text-sm text-gray-750 dark:text-gray-300">
            <% history.forEach(function(item) { %>
              <tr class="hover:bg-brand-cream/5 dark:hover:bg-brand-brown/5 transition-colors">
                <td class="py-4 px-6 flex items-center gap-4">
                  <img src="<%= item.novel.coverImage %>" alt="" class="w-10 h-14 object-cover rounded-md shadow-sm">
                  <div>
                    <span class="font-bold text-gray-800 dark:text-white leading-snug"><%= item.novel.title %></span>
                    <span class="block text-xs text-gray-400 mt-0.5">By <%= item.novel.authorName %></span>
                  </div>
                </td>
                <td class="py-4 px-6">
                  <span class="px-2.5 py-1 rounded-md text-xs font-semibold bg-brand-pink/20 text-brand-brown dark:text-brand-pink border border-brand-pink/10"><%= item.novel.genre %></span>
                </td>
                <td class="py-4 px-6 font-semibold">
                  Page <%= item.pageIndex + 1 %> <span class="text-xs text-gray-400 font-light">of <%= item.novel.contentPages.length %></span>
                </td>
                <td class="py-4 px-6">
                  <div class="flex items-center gap-3">
                    <!-- Progress Bar -->
                    <div class="w-28 bg-gray-200 dark:bg-brand-brown/20 rounded-full h-2 overflow-hidden flex flex-shrink-0">
                      <div class="bg-brand-brown dark:bg-brand-pink h-full" style="width: <%= item.progressPercent %>%"></div>
                    </div>
                    <span class="text-xs font-bold font-mono"><%= item.progressPercent %>%</span>
                  </div>
                </td>
                <td class="py-4 px-6 text-xs text-gray-400">
                  <%= new Date(item.updatedAt).toLocaleDateString() %> at <%= new Date(item.updatedAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                </td>
                <td class="py-4 px-6 text-right">
                  <a href="/novels/<%= item.novelId %>/read?page=<%= item.pageIndex %>" class="px-3.5 py-2 bg-brand-brown hover:bg-brand-accent text-white font-bold rounded-lg text-xs shadow-sm transition-colors inline-flex items-center gap-1">
                    Resume
                    <i data-lucide="play" class="w-3 h-3 fill-white"></i>
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% else { %>
    <div class="bg-white dark:bg-[#1E150F] p-16 rounded-2xl border border-brand-brown/10 dark:border-brand-brown/20 text-center text-gray-400 max-w-xl mx-auto mt-12 space-y-4">
      <div class="w-16 h-16 rounded-full bg-brand-cream dark:bg-brand-brown/10 text-brand-brown dark:text-brand-pink flex items-center justify-center mx-auto">
        <i data-lucide="notebook-tabs" class="w-8 h-8"></i>
      </div>
      <h2 class="font-serif text-xl font-bold text-gray-800 dark:text-white">No Reading History Found</h2>
      <p class="text-xs sm:text-sm text-gray-500 leading-relaxed">
        You haven't opened any books in the directory yet. Read any masterpiece and your checkpoints and percentages will sync automatically!
      </p>
      <a href="/novels" class="mt-4 inline-flex items-center gap-1.5 px-4 py-2 bg-brand-brown text-white font-semibold rounded-lg text-xs shadow-md">
        Explore Masterpieces
      </a>
    </div>
  <% } %>

</div>

<%- include('partials/footer') %>

<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex-grow">
  
  <div class="mb-8 border-b border-brand-brown/10 dark:border-brand-brown/25 pb-6">
    <a href="/dashboard" class="text-xs font-semibold text-brand-brown dark:text-brand-pink hover:underline flex items-center gap-1 mb-2">&larr; Back to Reader Dashboard</a>
    <h1 class="font-serif text-3xl font-bold text-gray-800 dark:text-brand-pink flex items-center gap-2">
      <i data-lucide="heart" class="w-7 h-7 text-red-500 fill-red-500 animate-pulse"></i>
      My Favorite Shelf
    </h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1 font-light">Your handpicked literary sanctuary. Access details or manage your favorites list instantly.</p>
  </div>

  <% if (favorites.length > 0) { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <% favorites.forEach(function(novel) { %>
        <div class="group bg-white dark:bg-[#1E150F] rounded-2xl overflow-hidden shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 border border-brand-brown/5 dark:border-brand-brown/15 flex flex-col h-full">
          <!-- Cover -->
          <div class="relative h-60 overflow-hidden bg-brand-cream/50">
            <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="<%= novel.coverImage %>" alt="<%= novel.title %>" loading="lazy">
            <div class="absolute top-3 right-3 bg-white/95 dark:bg-brand-dark/95 backdrop-blur px-2 py-1 rounded-lg border border-brand-brown/15 flex items-center gap-1 text-[10px] font-bold text-gray-850 dark:text-brand-pink">
              <i data-lucide="star" class="w-3 h-3 text-amber-500 fill-amber-500"></i>
              <%= novel.rating %>
            </div>
            <span class="absolute bottom-3 left-3 bg-brand-brown text-brand-cream text-[9px] px-2 py-0.5 rounded font-semibold uppercase tracking-wider">
              <%= novel.genre %>
            </span>
          </div>

          <!-- Details -->
          <div class="p-5 flex flex-col flex-grow">
            <span class="text-[10px] font-medium text-gray-400">By <%= novel.authorName %></span>
            <h3 class="font-serif text-base font-bold text-gray-800 dark:text-white group-hover:text-brand-brown dark:group-hover:text-brand-pink transition-colors truncate mt-0.5">
              <%= novel.title %>
            </h3>
            <p class="text-xs text-gray-505 dark:text-gray-355 line-clamp-2 leading-relaxed mb-4 mt-1.5 flex-grow">
              <%= novel.description %>
            </p>

            <div class="flex items-center justify-between border-t border-brand-brown/10 dark:border-brand-brown/15 pt-3.5 mt-auto gap-2">
              <form action="/novels/<%= novel._id %>/favorite" method="POST" class="inline">
                <button type="submit" class="p-2 border border-red-200 bg-red-50 dark:bg-red-950/10 hover:bg-red-100 text-red-650 dark:text-red-400 rounded-lg transition-colors text-xs flex items-center gap-1" title="Remove from favorites">
                  <i data-lucide="heart" class="w-4 h-4 fill-red-500 text-red-500"></i>
                  Unfavorite
                </button>
              </form>
              <a href="/novels/<%= novel._id %>" class="px-3.5 py-2 bg-brand-cream hover:bg-brand-pink/30 text-brand-brown dark:text-brand-pink font-semibold rounded-lg text-xs transition-colors flex items-center gap-1">
                Read Details
                <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
              </a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% else { %>
    <div class="bg-white dark:bg-[#1E150F] p-16 rounded-2xl border border-brand-brown/10 dark:border-brand-brown/20 text-center text-gray-400 max-w-xl mx-auto mt-12 space-y-4">
      <div class="w-16 h-16 rounded-full bg-brand-cream dark:bg-brand-brown/10 text-brand-brown dark:text-brand-pink flex items-center justify-center mx-auto">
        <i data-lucide="heart-off" class="w-8 h-8"></i>
      </div>
      <h2 class="font-serif text-xl font-bold text-gray-800 dark:text-white">Your Favorite Shelf is Empty</h2>
      <p class="text-xs sm:text-sm text-gray-500 leading-relaxed">
        You haven't handpicked any books yet. Open any book's details page and click the "Favorite" heart button to add them here!
      </p>
      <a href="/novels" class="mt-4 inline-flex items-center gap-1.5 px-4 py-2 bg-brand-brown text-white font-semibold rounded-lg text-xs shadow-md">
        Browse Novels Catalog
      </a>
    </div>
  <% } %>

</div>

<%- include('partials/footer') %>

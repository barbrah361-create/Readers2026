<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex-grow">
  
  <div class="mb-8 border-b border-brand-brown/10 dark:border-brand-brown/25 pb-6">
    <a href="/admin/novels" class="text-xs font-semibold text-brand-brown dark:text-brand-pink hover:underline flex items-center gap-1 mb-2">&larr; Back to Catalog Manager</a>
    <h1 class="font-serif text-3xl font-bold text-gray-800 dark:text-brand-pink">Edit Novel details</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Refine, expand, or adjust the archival data of <span class="italic text-brand-brown dark:text-brand-pink font-bold">"<%= novel.title %>"</span>.</p>
  </div>

  <form action="/admin/novels/edit/<%= novel._id %>" method="POST" enctype="multipart/form-data" class="bg-white dark:bg-[#1E150F] p-6 sm:p-10 rounded-2xl shadow-sm border border-brand-brown/10 dark:border-brand-brown/20 space-y-6">
    
    <!-- Title & Author -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        <label for="title" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Novel Title</label>
        <input type="text" id="title" name="title" value="<%= novel.title %>" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-brand-cream/10 text-gray-800 dark:text-white focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all">
      </div>
      <div>
        <label for="authorId" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Select Author</label>
        <select id="authorId" name="authorId" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-white dark:bg-[#1E150F] text-gray-800 dark:text-white focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all">
          <% authors.forEach(function(author) { %>
            <option value="<%= author._id %>" <%= String(author._id) === String(novel.authorId) ? 'selected' : '' %>><%= author.name %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <!-- Genre & Year -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        <label for="genre" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Genre / Category</label>
        <select id="genre" name="genre" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-white dark:bg-[#1E150F] text-gray-800 dark:text-white focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all">
          <% categories.forEach(function(category) { %>
            <option value="<%= category %>" <%= category === novel.genre ? 'selected' : '' %>><%= category %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label for="publicationYear" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Publication Year</label>
        <input type="number" id="publicationYear" name="publicationYear" value="<%= novel.publicationYear %>" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-brand-cream/10 text-gray-800 dark:text-white focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all">
      </div>
    </div>

    <!-- Cover Image & Short Description -->
    <div class="grid grid-cols-1 sm:grid-cols-12 gap-6 items-center">
      <div class="sm:col-span-2 flex justify-center">
        <img src="<%= novel.coverImage %>" alt="" class="w-16 h-24 object-cover rounded-lg border border-brand-brown/10 shadow-sm">
      </div>
      <div class="sm:col-span-10">
        <label for="coverImage" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Update Book Cover Photo (Optional)</label>
        <input type="file" id="coverImage" name="coverImage" accept="image/*" class="block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-brand-brown file:text-white hover:file:bg-brand-accent">
        <p class="text-xs text-gray-400 mt-1.5 font-light">Supported: png, jpg, jpeg, webp. Limit 5MB. Leave unprovided to preserve current artwork.</p>
      </div>
    </div>

    <div>
      <label for="description" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Short Card Description</label>
      <input type="text" id="description" name="description" value="<%= novel.description %>" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-brand-cream/10 text-gray-800 dark:text-white focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all">
    </div>

    <!-- Synopsis -->
    <div>
      <label for="synopsis" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Detailed Synopsis / Foreword</label>
      <textarea id="synopsis" name="synopsis" rows="4" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-brand-cream/10 text-gray-800 dark:text-white focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all"><%= novel.synopsis %></textarea>
    </div>

    <!-- Novel Contents Text Area with paging instructions -->
    <div>
      <label for="contentText" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Novel Reading Content</label>
      <div class="p-3 bg-brand-cream/40 dark:bg-brand-brown/5 text-brand-brown dark:text-gray-400 text-xs rounded-xl border border-brand-brown/10 mb-2 leading-relaxed">
        <p class="font-bold mb-1">📖 Page Separation Guide:</p>
        Use <span class="font-mono text-gray-800 dark:text-white bg-white dark:bg-black px-1.5 py-0.5 rounded border border-brand-brown/10">---PAGE---</span> on its own line to split chapters or reading screens.
      </div>
      <textarea id="contentText" name="contentText" rows="12" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-brand-cream/10 text-gray-800 dark:text-white font-serif focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all"><%= contentText %></textarea>
    </div>

    <div class="flex items-center justify-end gap-3 pt-4 border-t border-brand-brown/10 dark:border-brand-brown/25">
      <a href="/admin/novels" class="px-5 py-3 rounded-xl border border-brand-brown/20 text-gray-700 dark:text-gray-300 font-semibold text-sm hover:bg-brand-cream/10">Cancel</a>
      <button type="submit" class="px-6 py-3 bg-brand-brown hover:bg-brand-accent text-white font-semibold rounded-xl shadow-md hover:shadow-lg transition-all duration-200 text-sm flex items-center gap-2">
        <i data-lucide="check" class="w-4.5 h-4.5"></i>
        Save Catalog Updates
      </button>
    </div>

  </form>
</div>

<%- include('partials/footer') %>

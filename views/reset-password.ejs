<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>
<div class="flex-grow flex items-center justify-center py-20 px-4">
  <div class="max-w-md w-full glass-card p-8">
    <h1 class="font-serif text-2xl font-bold text-center mb-6">Reset Password</h1>
    <form action="/auth/reset-password" method="POST" class="space-y-4">
      <input type="hidden" name="token" value="<%= token %>">
      <div>
        <label class="block text-sm font-semibold mb-1">New Password</label>
        <input type="password" name="password" required minlength="8" class="w-full px-4 py-3 rounded-xl border border-brand-brown/20 dark:bg-brand-brown/10">
      </div>
      <div>
        <label class="block text-sm font-semibold mb-1">Confirm Password</label>
        <input type="password" name="confirmPassword" required class="w-full px-4 py-3 rounded-xl border border-brand-brown/20 dark:bg-brand-brown/10">
      </div>
      <button type="submit" class="w-full btn-brown py-3 rounded-xl font-semibold">Reset Password</button>
    </form>
  </div>
</div>
<%- include('partials/footer') %>

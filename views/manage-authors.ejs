<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex-grow">
  
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8 border-b border-brand-brown/10 dark:border-brand-brown/25 pb-6">
    <div>
      <a href="/admin" class="text-xs font-semibold text-brand-brown dark:text-brand-pink hover:underline flex items-center gap-1 mb-2">&larr; Back to Admin Center</a>
      <h1 class="font-serif text-3xl font-bold text-gray-800 dark:text-brand-pink flex items-center gap-2">
        <i data-lucide="users" class="w-7 h-7 text-brand-brown dark:text-brand-pink"></i>
        Manage Authors Directory
      </h1>
    </div>
    
    <a href="/admin/authors/add" class="px-5 py-3 bg-brand-brown hover:bg-brand-accent text-white font-bold rounded-xl shadow-md transition-all duration-200 text-sm flex items-center gap-2">
      <i data-lucide="plus" class="w-4.5 h-4.5"></i>
      Add New Author
    </a>
  </div>

  <!-- Authors Table -->
  <div class="bg-white dark:bg-[#1E150F] rounded-2xl shadow-sm border border-brand-brown/10 dark:border-brand-brown/20 overflow-hidden">
    <% if (authors.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b border-brand-brown/10 dark:border-brand-brown/15 bg-brand-cream/10 text-xs text-gray-400 font-bold uppercase">
              <th class="py-3.5 px-6">Author Photo & Name</th>
              <th class="py-3.5 px-6">Nationality</th>
              <th class="py-3.5 px-6">Famous Works</th>
              <th class="py-3.5 px-6">Novel Count</th>
              <th class="py-3.5 px-6 text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-brand-brown/5 text-sm text-gray-700 dark:text-gray-300">
            <% authors.forEach(function(author) { %>
              <tr class="hover:bg-brand-cream/5 dark:hover:bg-brand-brown/5 transition-colors">
                <td class="py-4 px-6 flex items-center gap-4">
                  <img src="<%= author.photo %>" alt="" class="w-10 h-10 rounded-full object-cover shadow-sm ring-2 ring-brand-pink/30">
                  <span class="font-bold text-gray-800 dark:text-white leading-snug"><%= author.name %></span>
                </td>
                <td class="py-4 px-6"><%= author.nationality %></td>
                <td class="py-4 px-6 max-w-xs truncate" title="<%= author.famousNovels %>"><%= author.famousNovels %></td>
                <td class="py-4 px-6 text-gray-400 font-mono"><%= author.novelCount || 0 %></td>
                <td class="py-4 px-6 text-right">
                  <div class="flex items-center justify-end gap-2.5">
                    <a href="/admin/authors/edit/<%= author._id %>" class="p-2 bg-brand-cream hover:bg-brand-pink/20 text-brand-brown dark:text-brand-pink rounded-lg transition-colors" title="Edit Author">
                      <i data-lucide="edit" class="w-4 h-4"></i>
                    </a>
                    <form action="/admin/authors/delete/<%= author._id %>" method="POST" class="inline" onsubmit="return confirm('Delete this author from the directory? This does NOT delete their books, but will leave them unlinked.');">
                      <button type="submit" class="p-2 bg-red-50 hover:bg-red-100 dark:bg-red-950/20 dark:hover:bg-red-900/30 text-red-600 dark:text-red-400 rounded-lg transition-colors" title="Delete Author">
                        <i data-lucide="trash-2" class="w-4 h-4"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="text-center py-20 text-gray-400">
        <i data-lucide="users" class="w-16 h-16 text-gray-300 mx-auto mb-4"></i>
        <p class="text-lg">No author records found in the database.</p>
        <a href="/admin/authors/add" class="mt-4 inline-flex items-center gap-2 px-4 py-2 bg-brand-brown text-white font-semibold rounded-lg text-sm">Add First Author &rarr;</a>
      </div>
    <% } %>
  </div>

</div>

<%- include('partials/footer') %>

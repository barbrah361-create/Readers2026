<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>
<div class="flex-grow flex items-center justify-center py-20 px-4">
  <div class="max-w-md w-full glass-card p-8">
    <h1 class="font-serif text-2xl font-bold text-center mb-6">Forgot Password</h1>
    <form action="/auth/forgot-password" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-semibold mb-1">Email Address</label>
        <input type="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-brand-brown/20 dark:bg-brand-brown/10">
      </div>
      <button type="submit" class="w-full btn-brown py-3 rounded-xl font-semibold">Send Reset Link</button>
    </form>
    <p class="text-center mt-4 text-sm"><a href="/auth/login" class="text-brand-brown dark:text-brand-pink hover:underline">Back to login</a></p>
  </div>
</div>
<%- include('partials/footer') %>

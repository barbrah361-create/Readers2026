            <i data-lucide="book-open" class="w-5 h-5"></i>
          </div>
          <span class="font-serif text-xl sm:text-2xl font-bold tracking-tight text-brand-brown dark:text-brand-pink">
            Elegance<span class="font-sans font-light text-gray-500 dark:text-gray-400">Library</span>
          </span>
        </a>
      </div>

      <!-- Desktop Navigation Menu -->
      <div class="hidden md:flex items-center space-x-1 lg:space-x-2">
        <a href="/" class="px-3 py-2 rounded-md text-sm font-medium transition-colors <%= currentPath === '/' ? 'text-brand-brown dark:text-brand-pink bg-brand-cream/50 dark:bg-brand-brown/20' : 'text-gray-600 dark:text-gray-300 hover:text-brand-brown dark:hover:text-brand-pink hover:bg-brand-cream/30 dark:hover:bg-brand-brown/10' %>">Home</a>
        <a href="/novels" class="px-3 py-2 rounded-md text-sm font-medium transition-colors <%= currentPath.startsWith('/novels') && !currentPath.includes('/categories') ? 'text-brand-brown dark:text-brand-pink bg-brand-cream/50 dark:bg-brand-brown/20' : 'text-gray-600 dark:text-gray-300 hover:text-brand-brown dark:hover:text-brand-pink hover:bg-brand-cream/30 dark:hover:bg-brand-brown/10' %>">Novels</a>
        <a href="/authors" class="px-3 py-2 rounded-md text-sm font-medium transition-colors <%= currentPath.startsWith('/authors') ? 'text-brand-brown dark:text-brand-pink bg-brand-cream/50 dark:bg-brand-brown/20' : 'text-gray-600 dark:text-gray-300 hover:text-brand-brown dark:hover:text-brand-pink hover:bg-brand-cream/30 dark:hover:bg-brand-brown/10' %>">Authors</a>
        <a href="/categories" class="px-3 py-2 rounded-md text-sm font-medium transition-colors <%= currentPath === '/categories' ? 'text-brand-brown dark:text-brand-pink bg-brand-cream/50 dark:bg-brand-brown/20' : 'text-gray-600 dark:text-gray-300 hover:text-brand-brown dark:hover:text-brand-pink hover:bg-brand-cream/30 dark:hover:bg-brand-brown/10' %>">Categories</a>
        <a href="/about" class="px-3 py-2 rounded-md text-sm font-medium transition-colors <%= currentPath === '/about' ? 'text-brand-brown dark:text-brand-pink bg-brand-cream/50 dark:bg-brand-brown/20' : 'text-gray-600 dark:text-gray-300 hover:text-brand-brown dark:hover:text-brand-pink hover:bg-brand-cream/30 dark:hover:bg-brand-brown/10' %>">About</a>
        <a href="/contact" class="px-3 py-2 rounded-md text-sm font-medium transition-colors <%= currentPath === '/contact' ? 'text-brand-brown dark:text-brand-pink bg-brand-cream/50 dark:bg-brand-brown/20' : 'text-gray-600 dark:text-gray-300 hover:text-brand-brown dark:hover:text-brand-pink hover:bg-brand-cream/30 dark:hover:bg-brand-brown/10' %>">Contact</a>
      </div>

      <!-- Action Buttons and User Controls -->
      <div class="hidden md:flex items-center space-x-4">
        <!-- Dark Mode Toggle -->
        <button id="theme-toggle-btn" class="p-2.5 rounded-full text-gray-500 hover:text-brand-brown dark:text-gray-400 dark:hover:text-brand-pink hover:bg-gray-100 dark:hover:bg-brand-brown/20 transition-all duration-200" title="Toggle Theme">
          <i data-lucide="sun" id="sun-icon" class="w-5 h-5 hidden dark:block"></i>
          <i data-lucide="moon" id="moon-icon" class="w-5 h-5 block dark:hidden"></i>
        </button>

        <% if (user) { %>
          <!-- Authenticated Menu -->

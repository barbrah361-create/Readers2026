<% if (typeof flash !== 'undefined') { %>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4" id="flash-message-container">
    <% if (flash.success && flash.success.length > 0) { %>
      <% flash.success.forEach(function(msg) { %>
        <div class="flex items-center justify-between p-4 mb-3 rounded-xl bg-green-50 dark:bg-green-950/20 text-green-800 dark:text-green-300 border border-green-200 dark:border-green-800 animate-pulse-once" role="alert">
          <div class="flex items-center gap-3">
            <i data-lucide="check-circle" class="w-5 h-5 flex-shrink-0"></i>
            <span class="text-sm font-medium"><%= msg %></span>
          </div>
          <button onclick="this.parentElement.remove()" class="p-1 rounded-lg text-green-500 hover:bg-green-100 dark:hover:bg-green-950/40">
            <i data-lucide="x" class="w-4 h-4"></i>
          </button>
        </div>
      <% }) %>
    <% } %>

    <% if (flash.error && flash.error.length > 0) { %>
      <% flash.error.forEach(function(msg) { %>
        <div class="flex items-center justify-between p-4 mb-3 rounded-xl bg-red-50 dark:bg-red-950/20 text-red-800 dark:text-red-300 border border-red-200 dark:border-red-800" role="alert">
          <div class="flex items-center gap-3">
            <i data-lucide="alert-triangle" class="w-5 h-5 flex-shrink-0"></i>
            <span class="text-sm font-medium"><%= msg %></span>
          </div>
          <button onclick="this.parentElement.remove()" class="p-1 rounded-lg text-red-500 hover:bg-red-100 dark:hover:bg-red-950/40">
            <i data-lucide="x" class="w-4 h-4"></i>
          </button>
        </div>
      <% }) %>
    <% } %>
  </div>
  
  <script>
    // Automatically close flash messages after 5 seconds
    setTimeout(() => {
      const container = document.getElementById('flash-message-container');
      if (container) {
        container.classList.add('transition-opacity', 'duration-500', 'opacity-0');
        setTimeout(() => container.remove(), 500);
      }
    }, 5000);
  </script>
<% } %>

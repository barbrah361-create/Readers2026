<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>
<div class="flex-grow flex items-center justify-center py-20 px-4">
  <div class="max-w-md w-full glass-card p-8 text-center">
    <i data-lucide="mail-check" class="w-16 h-16 text-brand-brown dark:text-brand-pink mx-auto mb-4"></i>
    <h1 class="font-serif text-2xl font-bold mb-2">Verify Your Email</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-6">We sent a verification link to <strong><%= email %></strong>. Check your inbox to unlock all features.</p>
    <form action="/auth/resend-verification" method="POST" class="mb-4">
      <button type="submit" class="btn-brown px-6 py-3 rounded-xl font-semibold">Resend Verification Email</button>
    </form>
    <p class="text-sm text-gray-500">In dev mode, check the server console for the verification link.</p>
  </div>
</div>
<%- include('partials/footer') %>

<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>

<section class="relative overflow-hidden bg-brand-cream/70 dark:bg-[#120C08]">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(247,214,224,0.15),transparent_45%)]"></div>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-end">
      <div class="lg:col-span-7 space-y-6">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-semibold uppercase tracking-[0.28em] bg-brand-brown text-brand-cream"> <%= article.category %> </span>
        <h1 class="font-serif text-5xl sm:text-6xl font-bold text-brand-dark dark:text-amber-100 leading-tight"><%= article.title %></h1>
        <p class="text-lg text-gray-600 dark:text-gray-300 max-w-3xl leading-relaxed"><%= article.subtitle %></p>

        <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
          <span><strong>By</strong> <%= article.author %></span>
          <span>&bull;</span>
          <span><%= article.date %></span>
          <span>&bull;</span>
          <span><%= article.readTime %></span>
        </div>
      </div>
      <div class="lg:col-span-5">
        <div class="rounded-[32px] overflow-hidden shadow-2xl border border-brand-brown/10 dark:border-brand-brown/20">
          <img src="<%= article.image %>" alt="<%= article.title %>" class="w-full h-[400px] object-cover">
        </div>
      </div>
    </div>
  </div>
</section>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 flex-grow">
  <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-10">
    <article class="space-y-8 text-gray-700 dark:text-gray-300">
      <% article.content.split('\n\n').forEach(function(paragraph) { %>
        <p class="text-base leading-relaxed"><%= paragraph %></p>
      <% }) %>
    </article>

    <aside class="space-y-6">
      <div class="book-card p-6 border border-brand-brown/10 dark:border-brand-brown/20 bg-white dark:bg-[#1E150F] shadow-sm">
        <h3 class="font-serif text-xl font-bold text-gray-800 dark:text-white mb-3">Article Snapshot</h3>
        <ul class="space-y-3 text-sm text-gray-600 dark:text-gray-400">
          <li><strong>Category:</strong> <%= article.category %></li>
          <li><strong>Author:</strong> <%= article.author %></li>
          <li><strong>Published:</strong> <%= article.date %></li>
          <li><strong>Read Time:</strong> <%= article.readTime %></li>
          <li><strong>Tags:</strong> <%= article.tags.join(', ') %></li>
        </ul>
      </div>
      <div class="book-card p-6 border border-brand-brown/10 dark:border-brand-brown/20 bg-brand-pink/10 dark:bg-[#2A0E12] shadow-sm">
        <h4 class="font-semibold text-gray-900 dark:text-amber-100">Want more curated reads?</h4>
        <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed mt-3">Visit our articles page to browse author spotlights, creative writing advice, and literary history pieces written for serious readers.</p>
        <a href="/articles" class="inline-flex items-center gap-2 mt-5 px-4 py-3 bg-brand-brown hover:bg-brand-accent text-white font-semibold rounded-xl transition-all duration-200">
          View All Articles
          <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </a>
      </div>
    </aside>
  </div>
</div>

<%- include('partials/footer') %>

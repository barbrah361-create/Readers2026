<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>

<div class="flex-grow flex items-center justify-center py-20 px-4 sm:px-6 lg:px-8 bg-cover bg-center relative" style="background-image: url('https://images.unsplash.com/photo-1481627834876-b7833e8f5570?w=1200&auto=format&fit=crop&q=80');">
  <!-- Subtle dark overlay -->
  <div class="absolute inset-0 bg-brand-cream/80 dark:bg-black/80 backdrop-blur-[4px]"></div>

  <div class="max-w-md w-full relative z-10 space-y-8 bg-white dark:bg-[#1E150F] p-8 sm:p-10 rounded-2xl shadow-xl border border-brand-brown/10 dark:border-brand-brown/20">
    <div class="text-center">
      <div class="w-12 h-12 rounded-xl bg-brand-brown text-brand-cream flex items-center justify-center mx-auto mb-4">
        <i data-lucide="key-round" class="w-6 h-6 text-brand-pink"></i>
      </div>
      <h2 class="font-serif text-3xl font-bold text-gray-800 dark:text-brand-pink">Welcome Back</h2>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-2">Sign in to unlock full offline-reading privileges.</p>
    </div>

    <!-- Login Form -->
    <form class="mt-8 space-y-6" action="/auth/login" method="POST">
      <div class="space-y-4">
        <div>
          <label for="email" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Registered Email</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-gray-400">
              <i data-lucide="mail" class="w-5 h-5"></i>
            </span>
            <input id="email" name="email" type="email" autocomplete="email" required class="block w-full pl-11 pr-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-brand-cream/10 text-gray-800 dark:text-white placeholder-gray-400 focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink focus:ring-1 focus:ring-brand-brown dark:focus:ring-brand-pink text-sm transition-all" placeholder="name@domain.com">
          </div>
        </div>

        <div>
          <label for="password" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Your Password</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-gray-400">
              <i data-lucide="lock" class="w-5 h-5"></i>
            </span>
            <input id="password" name="password" type="password" autocomplete="current-password" required class="block w-full pl-11 pr-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-brand-cream/10 text-gray-800 dark:text-white placeholder-gray-400 focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink focus:ring-1 focus:ring-brand-brown dark:focus:ring-brand-pink text-sm transition-all" placeholder="••••••••">
          </div>
        </div>
      </div>

      <div class="flex items-center justify-between text-xs">
        <label class="flex items-center gap-2 text-gray-500 dark:text-gray-400 cursor-pointer">
          <input type="checkbox" name="rememberMe" class="rounded border-gray-300 dark:border-gray-600 text-brand-brown focus:ring-brand-brown dark:focus:ring-brand-pink">
          Remember me
        </label>
        <a href="/auth/forgot-password" class="font-semibold text-brand-brown dark:text-brand-pink hover:underline">Forgot password?</a>
      </div>

      <div>
        <button type="submit" class="group relative w-full flex justify-center py-3.5 px-4 border border-transparent text-sm font-bold rounded-xl text-white bg-brand-brown hover:bg-brand-accent focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-brown dark:focus:ring-brand-pink shadow-md hover:shadow-lg transition-all duration-200">
          <span class="absolute left-0 inset-y-0 flex items-center pl-3">
            <i data-lucide="log-in" class="w-5 h-5 text-brand-pink group-hover:scale-110 transition-transform"></i>
          </span>
          Enter The Library
        </button>
      </div>
    </form>

    <!-- Demo details helper -->
    <div class="p-3 bg-brand-cream/40 dark:bg-brand-brown/10 rounded-xl text-xs text-brand-brown dark:text-gray-400 flex flex-col gap-1 border border-brand-brown/10">
      <p class="font-bold">🔑 Seed Accounts:</p>
      <p>Reader Account: <span class="font-mono text-gray-800 dark:text-white">reader@library.com</span> / <span class="font-mono text-gray-800 dark:text-white">reader</span></p>
      <p>Admin Account: <span class="font-mono text-gray-800 dark:text-white">admin@library.com</span> / <span class="font-mono text-gray-800 dark:text-white">admin</span></p>
    </div>

    <p class="text-center text-sm text-gray-500 dark:text-gray-400 mt-6">
      New to the archival? 
      <a href="/auth/register" class="font-bold text-brand-brown dark:text-brand-pink hover:underline">Create an account</a>
    </p>
  </div>
</div>

<%- include('partials/footer') %>

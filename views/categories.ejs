<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex-grow">
  
  <div class="text-center mb-16">
    <span class="text-brand-brown dark:text-brand-pink text-xs font-bold uppercase tracking-wider">The Archival Stacks</span>
    <h1 class="font-serif text-3xl sm:text-5xl font-bold mt-2 text-gray-800 dark:text-white">Explore Categories</h1>
    <p class="text-gray-500 dark:text-gray-400 max-w-xl mx-auto mt-4 text-sm sm:text-base leading-relaxed">
      Navigate through dedicated shelves housing historical pieces, award-winning African literature, fantasy adventures, and modern poetry.
    </p>
  </div>

  <% const categoryImages = {
    'Romance': '/uploads/romance novel.jpeg',
    'Mystery': '/uploads/mystery.jpg',
    'Fantasy': '/uploads/fantesy novel.png',
    'Historical Fiction': '/uploads/historical fiction.webp',
    'African Literature': '/uploads/African fictions.jpg',
    'Science Fiction': '/uploads/science fiction.jpg',
    'Horror': '/uploads/horror novel.webp',
    'Thriller': '/uploads/thriller.webp',
    'Adventure': '/uploads/adventure novel.webp',
    'Classics': '/uploads/classics novels.jpg',
    'Poetry': '/uploads/poetry.webp',
    'Drama': '/uploads/Drama novel.webp'
  } %>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
    <% categories.forEach(function(category) { %>
      <div class="group overflow-hidden rounded-3xl border border-brand-brown/10 bg-brand-cream shadow-sm hover:shadow-md transition-all duration-300">
        <div class="relative h-52 overflow-hidden">
          <img src="<%= categoryImages[category] || '/uploads/OIP.webp' %>" alt="<%= category %>" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105">
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
          <div class="absolute left-4 bottom-4 right-4">
            <span class="inline-flex items-center gap-2 rounded-full bg-brand-cream/90 px-3 py-1 text-[10px] font-semibold uppercase tracking-widest text-brand-brown shadow-sm">
              <%= category %>
            </span>
          </div>
        </div>

        <div class="p-6">
          <p class="text-sm text-brand-brown/80 leading-relaxed mb-6">
            <% if (category === 'Romance') { %> Swept by intense emotions, lifelong pledges, and warm chronicles.
            <% } else if (category === 'Mystery') { %> Shadows of doubt, master detectives, and hidden crime structures.
            <% } else if (category === 'Fantasy') { %> Kingdoms of magic lore, sorcery relics, and ancient quests.
            <% } else if (category === 'Historical Fiction') { %> Retold epochs, legendary figures, and real events framed by classical prose.
            <% } else if (category === 'African Literature') { %> Oral histories, cultural values, and award-winning contemporary accounts.
            <% } else if (category === 'Science Fiction') { %> Futuristic empires, deep space, and innovative technologies.
            <% } else if (category === 'Horror') { %> Spooky encounters, dark environments, and ancient curses.
            <% } else if (category === 'Thriller') { %> Suspenseful cliffhangers, ticking timers, and high-stakes conspiracies.
            <% } else if (category === 'Adventure') { %> Voyages through untamed wilderness, mountains, and hidden treasures.
            <% } else if (category === 'Classics') { %> Ageless masterpieces written across centuries of literary excellence.
            <% } else if (category === 'Poetry') { %> Structured stanzas, rhythmic expressions of the soul, and lyric collections.
            <% } else { %> Theatrical plays, tragedies, comedies, and dramatic dialogues.
            <% } %>
          </p>

          <a href="/novels?genre=<%= encodeURIComponent(category) %>" class="inline-flex items-center gap-2 px-4 py-2 bg-brand-brown text-brand-cream rounded-full text-xs font-semibold hover:bg-brand-accent transition-colors">
            Browse Category Shelf
            <i data-lucide="arrow-right" class="w-4 h-4"></i>
          </a>
        </div>
      </div>
    <% }) %>
  </div>

</div>

<%- include('partials/footer') %>

<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex-grow">
  
  <div class="mb-8 border-b border-brand-brown/10 dark:border-brand-brown/25 pb-6">
    <a href="/admin" class="text-xs font-semibold text-brand-brown dark:text-brand-pink hover:underline flex items-center gap-1 mb-2">&larr; Back to Admin Center</a>
    <h1 class="font-serif text-3xl font-bold text-gray-800 dark:text-brand-pink flex items-center gap-2">
      <i data-lucide="user-cog" class="w-7 h-7 text-brand-brown dark:text-brand-pink"></i>
      Manage Library Membership
    </h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Elevate reader roles, audit credentials, or suspend access for covenant breaches.</p>
  </div>

  <!-- Users Table Card -->
  <div class="bg-white dark:bg-[#1E150F] rounded-2xl shadow-sm border border-brand-brown/10 dark:border-brand-brown/20 overflow-hidden">
    <% if (users.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b border-brand-brown/10 dark:border-brand-brown/15 bg-brand-cream/10 text-xs text-gray-400 font-bold uppercase">
              <th class="py-3.5 px-6">Avatar & Username</th>
              <th class="py-3.5 px-6">Email Address</th>
              <th class="py-3.5 px-6">Assigned Role</th>
              <th class="py-3.5 px-6">Access Status</th>
              <th class="py-3.5 px-6">Registered On</th>
              <th class="py-3.5 px-6 text-right">Moderation Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-brand-brown/5 text-sm text-gray-700 dark:text-gray-300">
            <% users.forEach(function(member) { %>
              <tr class="hover:bg-brand-cream/5 dark:hover:bg-brand-brown/5 transition-colors">
                <td class="py-4 px-6 flex items-center gap-4">
                  <img src="<%= member.avatar || '/uploads/default-avatar.png' %>" alt="" class="w-9 h-9 rounded-full object-cover shadow-sm ring-2 ring-brand-pink/20">
                  <div>
                    <span class="font-bold text-gray-800 dark:text-white leading-snug"><%= member.username %></span>
                    <% if (member._id === user._id) { %>
                      <span class="inline-block ml-1.5 px-1.5 py-0.5 rounded text-[10px] bg-brand-brown text-white font-bold">You</span>
                    <% } %>
                  </div>
                </td>
                <td class="py-4 px-6 text-gray-500 dark:text-gray-400 font-mono text-xs"><%= member.email %></td>
                <td class="py-4 px-6">
                  <span class="px-2.5 py-1 rounded-md text-xs font-semibold <%= member.role === 'admin' ? 'bg-amber-100 text-amber-800 dark:bg-amber-950/20 dark:text-amber-300 border border-amber-200 dark:border-amber-900/30' : 'bg-brand-pink/20 text-brand-brown dark:text-brand-pink border border-brand-pink/10' %>">
                    <%= member.role %>
                  </span>
                </td>
                <td class="py-4 px-6">
                  <span class="px-2.5 py-1 rounded-md text-xs font-semibold <%= member.status === 'suspended' ? 'bg-red-50 text-red-800 dark:bg-red-950/20 dark:text-red-300 border border-red-200 dark:border-red-900/30' : 'bg-green-50 text-green-800 dark:bg-green-950/20 dark:text-green-300 border border-green-200 dark:border-green-900/30' %>">
                    <%= member.status || 'active' %>
                  </span>
                </td>
                <td class="py-4 px-6 text-gray-400 text-xs">
                  <%= new Date(member.createdAt).toLocaleDateString() %>
                </td>
                <td class="py-4 px-6 text-right">
                  <!-- Do not allow admin to suspend or alter their own roles -->
                  <% if (member._id !== user._id) { %>
                    <div class="flex items-center justify-end gap-2.5">
                      <!-- Toggle Role Form -->
                      <form action="/admin/users/role/<%= member._id %>" method="POST" class="inline">
                        <button type="submit" class="px-3 py-1.5 border border-brand-brown/10 hover:border-brand-brown dark:border-brand-brown/30 text-gray-700 dark:text-gray-300 hover:bg-brand-cream/10 rounded-lg text-xs font-semibold flex items-center gap-1">
                          <i data-lucide="shield-alert" class="w-3.5 h-3.5"></i>
                          Toggle Role
                        </button>
                      </form>
                      
                      <!-- Toggle Suspension Form -->
                      <form action="/admin/users/suspend/<%= member._id %>" method="POST" class="inline">
                        <button type="submit" class="px-3 py-1.5 <%= member.status === 'suspended' ? 'bg-green-50 text-green-700 dark:bg-green-950/20 dark:text-green-300 border border-green-200' : 'bg-red-50 text-red-700 dark:bg-red-950/20 dark:text-red-300 border border-red-100' %> hover:opacity-90 rounded-lg text-xs font-semibold flex items-center gap-1">
                          <% if (member.status === 'suspended') { %>
                            <i data-lucide="unlock" class="w-3.5 h-3.5"></i> Lift Suspension
                          <% } else { %>
                            <i data-lucide="user-x" class="w-3.5 h-3.5"></i> Suspend
                          <% } %>
                        </button>
                      </form>
                    </div>
                  <% } else { %>
                    <span class="text-xs text-gray-400 italic">Self Protections Active</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="text-sm text-gray-400 text-center py-10">No users found.</p>
    <% } %>
  </div>

</div>

<%- include('partials/footer') %>

<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex-grow">
  
  <!-- Page Header -->
  <div class="mb-12 text-center">
    <span class="text-brand-brown dark:text-brand-pink text-xs font-bold uppercase tracking-wider">Literary Guild Masters</span>
    <h1 class="font-serif text-3xl sm:text-5xl font-bold mt-2 text-gray-800 dark:text-white">Meet Famous Authors</h1>
    <p class="text-gray-500 dark:text-gray-400 max-w-xl mx-auto mt-4 text-sm sm:text-base leading-relaxed">
      Learn about classical and modern creators who constructed the prose matching our collections. Read their detailed biographies and explore their works.
    </p>
  </div>

  <% const quoteCards = [
    {
      name: 'Chinua Achebe',
      image: '/uploads/chinu achebe.jpg',
      quote: '“The world is like a Mask dancing. If you want to see it well, you do not stand in one place.”'
    },
    {
      name: 'Maya Angelou',
      image: '/uploads/maya-angelou-4.jpg',
      quote: '“There is no greater agony than bearing an untold story inside you.”'
    },
    {
      name: 'J.K. Rowling',
      image: '/uploads/j.k rawling.webp',
      quote: '“We do not need magic to transform our world. We carry all the power we need inside ourselves already.”'
    },
    {
      name: 'Ngũgĩ wa Thiong\'o',
      image: '/uploads/Ngugi wa thiongo.jpeg',
      quote: '“The writer is a politician, although he is not a member of any political party.”'
    }
  ]; %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
    <% quoteCards.forEach(function(card) { %>
      <div class="group overflow-hidden rounded-3xl border border-brand-brown/10 bg-brand-cream shadow-sm hover:shadow-md transition-all duration-200">
        <div class="relative h-56 overflow-hidden">
          <img src="<%= card.image %>" alt="<%= card.name %>" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105">
          <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/10 to-transparent"></div>
          <div class="absolute inset-x-0 bottom-0 p-6 text-brand-cream">
            <span class="text-[10px] uppercase tracking-[0.25em] font-semibold text-brand-pink">Quote by <%= card.name %></span>
            <p class="mt-3 text-sm leading-relaxed font-medium"><%= card.quote %></p>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Authors grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
    <% authors.forEach(function(author) { %>
      <div class="group book-card overflow-hidden hover:-translate-y-1">
        
        <div class="relative h-64 bg-brand-cream/45 overflow-hidden flex items-center justify-center">
          <img src="<%= author.photo %>" alt="<%= author.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy">
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-70"></div>
          
          <div class="absolute bottom-4 left-4 right-4 text-white">
            <span class="text-[10px] font-bold text-brand-pink uppercase tracking-widest"><%= author.nationality %></span>
            <h2 class="font-serif text-lg sm:text-xl font-bold truncate mt-0.5"><%= author.name %></h2>
          </div>
        </div>

        <div class="p-5 flex flex-col h-44 justify-between">
          <div>
            <p class="text-xs text-gray-500 dark:text-gray-400 font-semibold mb-2 flex items-center gap-1.5">
              <i data-lucide="award" class="w-4 h-4 text-amber-500"></i>
              <%= author.literaryAchievements %>
            </p>
            <p class="text-xs text-gray-600 dark:text-gray-300 line-clamp-3 leading-relaxed">
              <%= author.bio %>
            </p>
          </div>
          <div class="flex items-center justify-between border-t border-brand-brown/10 dark:border-brand-brown/15 pt-3.5 text-xs gap-2">
            <span class="text-gray-400"><%= author.novelCount || 0 %> Books Catalogued</span>
            <div class="flex items-center gap-2">
              <% if (author.externalLink) { %>
                <a href="<%= author.externalLink %>" target="_blank" rel="noopener noreferrer" class="text-brand-pink font-bold hover:underline">Explore Online</a>
              <% } %>
              <a href="/authors/<%= author._id %>" class="text-brand-brown dark:text-brand-pink font-bold hover:underline">Full Biography &rarr;</a>
            </div>
          </div>
        </div>

      </div>
    <% }) %>
  </div>

</div>

<%- include('partials/footer') %>

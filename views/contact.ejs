<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>

<div class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  
  <div class="text-center mb-16">
    <span class="text-brand-brown dark:text-brand-pink text-xs font-bold uppercase tracking-wider">Gathering Gates</span>
    <h1 class="font-serif text-3xl sm:text-5xl font-bold mt-2 text-gray-800 dark:text-white">Contact Our Curators</h1>
    <p class="text-gray-500 dark:text-gray-400 max-w-xl mx-auto mt-4 text-sm sm:text-base leading-relaxed">
      Have a question regarding book copyright, author registrations, or membership privileges? Reach out to our master archivists.
    </p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
    
    <!-- Left: Contact Details & Info -->
    <div class="lg:col-span-5 space-y-8">
      <div class="bg-white dark:bg-[#1E150F] p-6 sm:p-8 rounded-2xl border border-brand-brown/10 dark:border-brand-brown/20 shadow-sm space-y-6">
        <h2 class="font-serif text-2xl font-bold text-gray-800 dark:text-brand-pink">Library Archives</h2>
        <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
          The physical sanctuary is open to public guild members by prior booking. Walk-ins are permitted on literary festival days.
        </p>

        <div class="space-y-4 text-sm">
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-xl bg-brand-cream dark:bg-brand-brown/20 text-brand-brown dark:text-brand-pink flex items-center justify-center flex-shrink-0 shadow-sm">
              <i data-lucide="map-pin" class="w-5 h-5"></i>
            </div>
            <div>
              <p class="font-bold text-gray-800 dark:text-white">Physical Sanctum</p>
              <p class="text-gray-500 dark:text-gray-400 mt-0.5">Eldoret, Kenya</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-xl bg-brand-cream dark:bg-brand-brown/20 text-brand-brown dark:text-brand-pink flex items-center justify-center flex-shrink-0 shadow-sm">
              <i data-lucide="mail" class="w-5 h-5"></i>
            </div>
            <div>
              <p class="font-bold text-gray-800 dark:text-white">Postal Wire</p>
              <a href="mailto:curator@elegancelibrary.com" class="text-brand-brown dark:text-brand-pink hover:underline text-xs sm:text-sm mt-0.5 block">curator@elegancelibrary.com</a>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-xl bg-brand-cream dark:bg-brand-brown/20 text-brand-brown dark:text-brand-pink flex items-center justify-center flex-shrink-0 shadow-sm">
              <i data-lucide="phone" class="w-5 h-5"></i>
            </div>
            <div>
              <p class="font-bold text-gray-800 dark:text-white">Vocal Connection</p>
              <p class="text-gray-500 dark:text-gray-400 mt-0.5">0726625144</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Static Map Preview -->
      <div class="rounded-2xl overflow-hidden border border-brand-brown/10 shadow-sm h-64 bg-brand-cream flex flex-col justify-center items-center text-center p-6 relative">
        <div class="absolute inset-0 opacity-40 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1524661135-423995f22d0b?w=600&auto=format&fit=crop&q=80');"></div>
        <div class="relative z-10 space-y-2">
          <div class="w-10 h-10 rounded-full bg-brand-brown text-white flex items-center justify-center mx-auto shadow-md">
            <i data-lucide="map" class="w-5 h-5"></i>
          </div>
          <h3 class="font-bold text-gray-800 dark:text-brand-dark">Eldoret Library Hub</h3>
          <p class="text-xs text-gray-600 dark:text-gray-700 font-medium">Click to navigate via GPS Scroll</p>
        </div>
      </div>
    </div>

    <!-- Right: Message Form -->
    <div class="lg:col-span-7 bg-white dark:bg-[#1E150F] p-6 sm:p-10 rounded-2xl border border-brand-brown/10 dark:border-brand-brown/20 shadow-sm">
      <h2 class="font-serif text-2xl font-bold text-gray-800 dark:text-brand-pink mb-6 pb-4 border-b border-brand-brown/10 dark:border-brand-brown/15 flex items-center gap-2">
        <i data-lucide="pen-tool" class="w-5 h-5 text-brand-brown dark:text-brand-pink"></i>
        Pen a Dispatch
      </h2>

      <form action="/contact" method="POST" class="space-y-5" onsubmit="event.preventDefault(); alert('Your message has been dispatched successfully! A library curator will reply shortly.'); this.reset();">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="name" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Your Name</label>
            <input type="text" id="name" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-brand-cream/10 text-gray-800 dark:text-white focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all" placeholder="John Milton">
          </div>
          <div>
            <label for="email" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Email Address</label>
            <input type="email" id="email" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-brand-cream/10 text-gray-800 dark:text-white focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all" placeholder="john@milton.com">
          </div>
        </div>

        <div>
          <label for="subject" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Dispatch Subject</label>
          <input type="text" id="subject" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-brand-cream/10 text-gray-800 dark:text-white focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all" placeholder="Copyright feedback, account setup, etc.">
        </div>

        <div>
          <label for="message" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Message Content</label>
          <textarea id="message" rows="5" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-brand-cream/10 text-gray-800 dark:text-white placeholder-gray-400 focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all" placeholder="Compose your thoughts or list any book requests here..."></textarea>
        </div>

        <div class="pt-2 flex justify-end">
          <button type="submit" class="px-6 py-3.5 bg-brand-brown hover:bg-brand-accent text-white font-bold rounded-xl shadow-md hover:shadow-lg transition-all duration-200 text-sm flex items-center gap-2">
            <i data-lucide="send" class="w-4.5 h-4.5"></i>
            Dispatch Message
          </button>
        </div>
      </form>
    </div>

  </div>
</div>

<%- include('partials/footer') %>

<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex-grow">
  
  <div class="mb-8 border-b border-brand-brown/10 dark:border-brand-brown/25 pb-6">
    <a href="/admin/novels" class="text-xs font-semibold text-brand-brown dark:text-brand-pink hover:underline flex items-center gap-1 mb-2">&larr; Back to Catalog Manager</a>
    <h1 class="font-serif text-3xl font-bold text-gray-800 dark:text-brand-pink">Add New Masterpiece</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Populate the digital stacks with a fresh novel, biography, or poetic record.</p>
  </div>

  <form action="/admin/novels/add" method="POST" enctype="multipart/form-data" class="bg-white dark:bg-[#1E150F] p-6 sm:p-10 rounded-2xl shadow-sm border border-brand-brown/10 dark:border-brand-brown/20 space-y-6">
    
    <!-- Title & Author -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        <label for="title" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Novel Title</label>
        <input type="text" id="title" name="title" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-brand-cream/10 text-gray-800 dark:text-white focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all" placeholder="e.g. Romeo and Juliet">
      </div>
      <div>
        <label for="authorId" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Select Author</label>
        <select id="authorId" name="authorId" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-white dark:bg-[#1E150F] text-gray-800 dark:text-white focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all">
          <option value="" disabled selected>-- Select Author Profile --</option>
          <% authors.forEach(function(author) { %>
            <option value="<%= author._id %>"><%= author.name %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <!-- Genre & Year -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        <label for="genre" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Genre / Category</label>
        <select id="genre" name="genre" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-white dark:bg-[#1E150F] text-gray-800 dark:text-white focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all">
          <option value="" disabled selected>-- Choose Shelf --</option>
          <% categories.forEach(function(category) { %>
            <option value="<%= category %>"><%= category %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label for="publicationYear" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Publication Year</label>
        <input type="number" id="publicationYear" name="publicationYear" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-brand-cream/10 text-gray-800 dark:text-white focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all" placeholder="e.g. 1597">
      </div>
    </div>

    <!-- Cover Image & Short Description -->
    <div class="grid grid-cols-1 gap-6">
      <div>
        <label for="coverImage" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Book Cover Photo</label>
        <input type="file" id="coverImage" name="coverImage" accept="image/*" class="block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-brand-brown file:text-white hover:file:bg-brand-accent">
        <p class="text-xs text-gray-400 mt-1.5">Supported: png, jpg, jpeg, webp. Limit 5MB. If unprovided, a default archival cover will represent the book.</p>
      </div>
      <div>
        <label for="description" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Short Card Description</label>
        <input type="text" id="description" name="description" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-brand-cream/10 text-gray-800 dark:text-white focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all" placeholder="A brief, 1-2 sentence description shown in browse cards.">
      </div>
    </div>

    <!-- Synopsis -->
    <div>
      <label for="synopsis" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Detailed Synopsis / Foreword</label>
      <textarea id="synopsis" name="synopsis" rows="4" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-brand-cream/10 text-gray-800 dark:text-white placeholder-gray-400 focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all" placeholder="Enter detailed plot foreword, accolades, and historical notes..."></textarea>
    </div>

    <!-- Novel Contents Text Area with paging instructions -->
    <div>
      <label for="contentText" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Novel Reading Content</label>
      <div class="p-3 bg-brand-cream/40 dark:bg-brand-brown/5 text-brand-brown dark:text-gray-400 text-xs rounded-xl border border-brand-brown/10 mb-2 leading-relaxed">
        <p class="font-bold mb-1">📖 Page Separation Guide:</p>
        Use <span class="font-mono text-gray-800 dark:text-white bg-white dark:bg-black px-1.5 py-0.5 rounded border border-brand-brown/10">---PAGE---</span> on its own line to split chapters or reading screens. For example:
        <pre class="font-mono mt-1 text-[10px] bg-white dark:bg-black p-2 rounded text-gray-500 overflow-x-auto">This is the text of Page 1.

---PAGE---

This is the text of Page 2.</pre>
      </div>
      <textarea id="contentText" name="contentText" rows="12" required class="block w-full px-4 py-3 border border-brand-brown/20 dark:border-brand-brown/30 rounded-xl bg-brand-cream/10 text-gray-800 dark:text-white font-serif placeholder-gray-400 focus:outline-none focus:border-brand-brown dark:focus:border-brand-pink text-sm transition-all" placeholder="Write or paste your book content pages separated by ---PAGE--- here..."></textarea>
    </div>

    <div class="flex items-center justify-end gap-3 pt-4 border-t border-brand-brown/10 dark:border-brand-brown/25">
      <a href="/admin/novels" class="px-5 py-3 rounded-xl border border-brand-brown/20 text-gray-700 dark:text-gray-300 font-semibold text-sm hover:bg-brand-cream/10">Cancel</a>
      <button type="submit" class="px-6 py-3 bg-brand-brown hover:bg-brand-accent text-white font-semibold rounded-xl shadow-md hover:shadow-lg transition-all duration-200 text-sm flex items-center gap-2">
        <i data-lucide="plus" class="w-4.5 h-4.5"></i>
        Add Masterpiece to Stacks
      </button>
    </div>

  </form>
</div>

<%- include('partials/footer') %>

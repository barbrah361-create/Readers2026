<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="flex-grow flex items-center justify-center py-24 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full text-center space-y-6 bg-white dark:bg-[#1E150F] p-8 sm:p-10 rounded-3xl border border-brand-brown/10 dark:border-brand-brown/20 shadow-sm">
    
    <!-- Large Status Indicator -->
    <div class="relative inline-block">
      <h1 class="font-serif text-8xl font-black text-brand-brown/15 dark:text-brand-pink/10 tracking-wider">
        <%= typeof status !== 'undefined' ? status : '404' %>
      </h1>
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="w-16 h-16 rounded-full bg-brand-cream dark:bg-brand-brown/15 text-brand-brown dark:text-brand-pink flex items-center justify-center shadow-md">
          <% if (typeof status !== 'undefined' && status === 403) { %>
            <i data-lucide="shield-alert" class="w-8 h-8 text-brand-brown dark:text-brand-pink"></i>
          <% } else if (typeof status !== 'undefined' && status === 500) { %>
            <i data-lucide="server-crash" class="w-8 h-8 text-brand-brown dark:text-brand-pink"></i>
          <% } else { %>
            <i data-lucide="compass" class="w-8 h-8 text-brand-brown dark:text-brand-pink"></i>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Error Descriptors -->
    <div class="space-y-2">
      <h2 class="font-serif text-2xl sm:text-3xl font-bold text-gray-800 dark:text-brand-pink">
        <%= typeof title !== 'undefined' ? title : 'Page Not Catalogued' %>
      </h2>
      <p class="text-xs sm:text-sm text-gray-500 dark:text-gray-400 leading-relaxed font-light">
        <%= typeof message !== 'undefined' ? message : 'The manuscript or gate you are searching for does not exist in our library archives. It might have been re-shelved or de-catalogued.' %>
      </p>
    </div>

    <!-- Action Shortcuts -->
    <div class="pt-4 flex flex-col sm:flex-row gap-3 items-center justify-center">
      <a href="/" class="w-full sm:w-auto px-6 py-3 bg-brand-brown hover:bg-brand-accent text-white font-bold rounded-xl shadow-md text-xs transition-colors flex items-center justify-center gap-1.5">
        <i data-lucide="home" class="w-4 h-4"></i>
        Return to Home Gates
      </a>
      <a href="/contact" class="w-full sm:w-auto px-6 py-3 border border-brand-brown/20 hover:bg-brand-cream/10 text-gray-700 dark:text-gray-300 font-semibold rounded-xl text-xs transition-colors flex items-center justify-center gap-1.5">
        <i data-lucide="mail" class="w-4 h-4"></i>
        Report Archive Issue
      </a>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
